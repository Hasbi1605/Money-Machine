# ===========================
# AI Money Machine Configuration
# ===========================

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Blog Platforms ---
# WordPress (self-hosted)
WP_URL=https://your-wordpress-site.com
WP_USERNAME=admin
WP_PASSWORD=your_app_password

# Medium
MEDIUM_TOKEN=your_medium_integration_token

# Blogger
BLOGGER_BLOG_ID=your_blogger_blog_id
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# --- Affiliate Links ---
AMAZON_AFFILIATE_TAG=your-tag-20
TOKOPEDIA_AFFILIATE_ID=your_tokopedia_id
SHOPEE_AFFILIATE_ID=your_shopee_id

# --- YouTube ---
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# --- TikTok ---
TIKTOK_SESSION_ID=your_tiktok_session

# --- Pexels (Free Stock Video) ---
PEXELS_API_KEY=your_pexels_api_key

# --- Telegram Monitoring ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Micro-SaaS ---
SAAS_HOST=0.0.0.0
SAAS_PORT=8000
SAAS_SECRET_KEY=change_this_to_random_string
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_key
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# --- General ---
CONTENT_LANGUAGES=en,id
TIMEZONE=Asia/Jakarta
LOG_LEVEL=INFO
